{
  "version": 2,
  "functions": {
    "api/audit.js": {
      "includeFiles": "api/apple-token.js"
    },
    "api/submit-audit.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/audit",
      "dest": "/api/audit.js"
    },
    {
      "src": "/api/submit-audit",
      "dest": "/api/submit-audit.js"
    },
    {
      "src": "/dashboard.html",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    },
    {
      "src": "/faq.html",
      "dest": "/public/faq.html"
    },
    {
      "src": "/se7ven_labs_popped.png",
      "dest": "/public/se7ven_labs_popped.png"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}

