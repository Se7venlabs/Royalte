{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/demo", "dest": "/public/demo.html" },
    { "src": "/demo.html", "dest": "/public/demo.html" },
    { "src": "/faq", "dest": "/public/faq.html" },
    { "src": "/faq.html", "dest": "/public/faq.html" },
    { "src": "/dev-spec", "dest": "/public/dev-spec.html" },
    { "src": "/dev-spec.html", "dest": "/public/dev-spec.html" },
    { "src": "/se7ven_labs_popped.png", "dest": "/public/se7ven_labs_popped.png" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
