{
  "version": 2,
  "functions": {
    "api/audit.js": {
      "includeFiles": "api/apple-token.js",
      "maxDuration": 30
    },
    "api/identify.js": {
      "includeFiles": "api/apple-token.js",
      "maxDuration": 10
    },
    "api/resolve-artist.js": {
      "includeFiles": "api/apple-token.js"
    },
    "api/submit-audit.js": {
      "maxDuration": 60
    },
    "api/cron/rescan.js": {
      "maxDuration": 300,
      "includeFiles": "api/apple-token.js"
    },
    "api/cron/scan-subscription.js": {
      "maxDuration": 60,
      "includeFiles": "api/apple-token.js"
    }
  },
  "crons": [
    {
      "path": "/api/cron/rescan",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    {
      "src": "/pricing.html",
      "status": 302,
      "headers": { "Location": "/" }
    },
    {
      "src": "/dev-spec.html",
      "status": 302,
      "headers": { "Location": "/" }
    },
    {
      "src": "/api/audit",
      "dest": "/api/audit.js"
    },
    {
      "src": "/api/identify",
      "dest": "/api/identify.js"
    },
    {
      "src": "/api/resolve-artist",
      "dest": "/api/resolve-artist.js"
    },
    {
      "src": "/api/submit-audit",
      "dest": "/api/submit-audit.js"
    },
    {
      "src": "/api/cron/rescan",
      "dest": "/api/cron/rescan.js"
    },
    {
      "src": "/api/cron/scan-subscription",
      "dest": "/api/cron/scan-subscription.js"
    },
    {
      "src": "/api/founding-artist/reserve",
      "dest": "/api/founding-artist/reserve.js"
    },
    {
      "src": "/auth/callback",
      "dest": "/api/auth/callback.js"
    },
    {
      "src": "/auth/reset-password",
      "dest": "/api/auth/reset-password.js"
    },
    {
      "src": "/api/claim-scan",
      "dest": "/api/claim-scan.js"
    },
    {
      "src": "/api/save-music-rights-profile",
      "dest": "/api/save-music-rights-profile.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    },
    {
      "src": "/what-we-do",
      "dest": "/public/what-we-do.html"
    },
    {
      "src": "/faq.html",
      "dest": "/public/faq.html"
    },
    {
      "src": "/se7ven_labs_popped.png",
      "dest": "/public/se7ven_labs_popped.png"
    },
    {
      "src": "/sw.js",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "content-type": "application/javascript; charset=utf-8"
      },
      "dest": "/public/sw.js"
    },
    {
      "src": "/mission-control.webmanifest",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "content-type": "application/manifest+json; charset=utf-8"
      },
      "dest": "/public/mission-control.webmanifest"
    },
    {
      "src": "/mission-control-preview",
      "status": 307,
      "headers": { "Location": "/mission-control.html?preview=1" }
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}

