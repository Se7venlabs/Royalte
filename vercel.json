{
  "version": 2,
  "builds": [
    {
      "src": "api/audit.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["api/apple-token.js"] }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/audit",
      "dest": "/api/audit.js"
    },
    {
      "src": "/dashboard.html",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    },
    {
      "src": "/faq.html",
      "dest": "/public/faq.html"
    },
    {
      "src": "/se7ven_labs_popped.png",
      "dest": "/public/se7ven_labs_popped.png"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
