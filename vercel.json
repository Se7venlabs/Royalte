{
  "version": 2,
  "functions": {
    "api/audit.js": {
      "includeFiles": "api/apple-token.js"
    },
    "api/submit-audit.js": {
      "maxDuration": 60
    },
    "api/cron/rescan.js": {
      "maxDuration": 300,
      "includeFiles": "api/apple-token.js"
    }
  },
  "crons": [
    {
      "path": "/api/cron/rescan",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    {
      "src": "/pricing.html",
      "status": 302,
      "headers": { "Location": "/" }
    },
    {
      "src": "/dev-spec.html",
      "status": 302,
      "headers": { "Location": "/" }
    },
    {
      "src": "/api/audit",
      "dest": "/api/audit.js"
    },
    {
      "src": "/api/submit-audit",
      "dest": "/api/submit-audit.js"
    },
    {
      "src": "/api/cron/rescan",
      "dest": "/api/cron/rescan.js"
    },
    {
      "src": "/api/founding-artist/reserve",
      "dest": "/api/founding-artist/reserve.js"
    },
    {
      "src": "/auth/callback",
      "dest": "/api/auth/callback.js"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    },
    {
      "src": "/faq.html",
      "dest": "/public/faq.html"
    },
    {
      "src": "/se7ven_labs_popped.png",
      "dest": "/public/se7ven_labs_popped.png"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}

